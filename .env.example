# =============================================================================
# .env.example — Copie para .env e preencha os valores
#   cp .env.example .env && nano .env
# =============================================================================

# --- Domínio / Acesso ---
# Use seu domínio (ex: meulavajato.com.br) ou o IP da VPS para teste em HTTP
DOMAIN=seu-dominio-ou-ip
NEXT_PUBLIC_API_URL=https://seu-dominio-ou-ip/api/v1

# --- Banco de dados ---
POSTGRES_USER=lava
POSTGRES_DB=lavadb
# Invente uma senha forte (evite caracteres especiais que quebram URL)
POSTGRES_PASSWORD=

# --- Segurança ---
# Gere com: openssl rand -hex 32
SECRET_KEY=
# Gere com: openssl rand -hex 16  (DEVE ter exatamente 32 caracteres)
ENCRYPTION_KEY=

# --- Visão computacional ---
# yolo11n.pt (nano, leve) | yolo11s.pt | yolo11m.pt (mais preciso, mais pesado)
YOLO_MODEL=yolo11n.pt

# --- Worker ---
RECONNECT_INTERVAL=30
SAVE_SNAPSHOTS=true
LOG_LEVEL=INFO

# --- Retenção ---
LOG_RETENTION_DAYS=30
SNAPSHOT_RETENTION_DAYS=7
